{
  "name": "zentext",
  "version": "0.1.0",
  "description": "A local-first shared context and memory layer for AI coding agents.",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "scripts": {
    "build": "tsc",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "typecheck:test": "tsc --noEmit -p tsconfig.test.json"
  },
  "license": "UNLICENSED",
  "private": true,
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "better-sqlite3": "^12.2.0",
    "ulid": "^3.0.1",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^24.0.0",
    "typescript": "^5.8.0",
    "vitest": "^3.0.0"
  },
  "allowScripts": {
    "better-sqlite3": true,
    "esbuild": true,
    "fsevents": true
  },
  "bin": {
    "zentext": "dist/cli/cli.js",
    "zentext-mcp": "dist/mcp/bin.js"
  },
  "files": [
    "dist",
    "README.md",
    "docs/mcp.md",
    "!dist/proof"
  ]
}
